.DS_Store

# Local virtualenvs and sandboxes
venv/
voice-agents-hack/

# Xcode local state
DerivedData/
build/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
xcuserdata/
*.xcworkspace/xcuserdata/

# Keep only the vendored iOS framework from the local cactus workspace
cactus/*
!cactus/apple/
cactus/apple/*
!cactus/apple/cactus-ios.xcframework/
!cactus/apple/cactus-ios.xcframework/**

# Ignore large local model and tooling folders
cactus/weights/
cactus/venv/
cactus/.venv/
cactus/.git/
cactus/.gitmodules

# Skill-install scaffolding (regenerated via `npx skills add`)
.agents/
skills/
skills-lock.json
.junie/
.claude/skills/supabase
.claude/skills/supabase-postgres-best-practices

# Stale pre-merge copy of the cactus xcframework (canonical path is
# cactus/apple/cactus-ios.xcframework)
cactus-ios.xcframework
